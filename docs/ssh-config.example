Host github.proteus
	HostName github.com
	User git
  IdentityFile ~/.ssh/id_rsa_proteus.cpi.3
	ForwardAgent yes


# Use
#	git clone git@github.proteus:<user>/<repo>.git
#
# Show remote
#
#  git remote get-url origin --all
#
# Other options include the following
#
#  Set In the shell:
#
# 	GIT_SSH_COMMAND="ssh -i ~/.ssh/your_private_key"
#
# Or run in the local git folder run
#
# 	git config core.sshCommand "ssh -i ~/.ssh/your_private_key -F /dev/null"
#
# Also create
#   ~/.config/environment.d/bitwarden-ssh.conf 
# with content
# 	SSH_AUTH_SOCK="${HOME}/.bitwarden-ssh-agent.sock"
#
# To make sure openssh-agent do not highjack do the following
# 
#
# 	systemctl --user mask ssh-agent.socket gcr-ssh-agent.socket gpg-agent-ssh.socket
#
# In future to revert
#
#  systemctl --user unmask ssh-agent.socket gcr-ssh-agent.socket gpg-agent-ssh.socket
#
#  systemctl --user enable --now ssh-agent.socket
#
  

