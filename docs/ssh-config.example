# These are scratch pad accounts that share the same SSH key; 
# and also the email (pilakkat@gmail.com), aliased to 
# pilakkat+<repo-name>@gmail.com
#
# It's not really necessay to have unique SSH key's for these accounts, 
# as they are used for authentication only. However the registered 
# email address must be unique for each account, as Github uses 
# the email address as the primary identifier for the account.
#
# E.g. : "git clone git@github.skp64-pvt01.com:skp64-pvt01/Landmark-Meritus.git"
#
############################################################
#  Key status       : 👍
#  password status  : 👍
#
