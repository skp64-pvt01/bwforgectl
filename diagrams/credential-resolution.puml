@startuml credential-resolution
skinparam backgroundColor #FEFEFE
skinparam sequenceMessageAlign direction

title Credential resolution flow

participant "cli.py\n_resolve_credentials()" as RESOLVE
participant "cli.py\n_make_client()" as MAKE
participant "CredentialStore" as STORE
participant "OS Keyring" as KEYRING
database "~/.config/\nssh_bw/\ncredentials.enc" as ENCFILE
actor "User\n(stdin)" as USER

== Step 1: Check CLI args ==
RESOLVE -> RESOLVE : args.email set?
RESOLVE -> RESOLVE : args.password set?
note right: Used directly if present

== Step 2: Check env vars ==
RESOLVE -> RESOLVE : os.environ.get(\n  "BW_EMAIL")?
RESOLVE -> RESOLVE : os.environ.get(\n  "BW_PASSWORD")?
note right: Overrides store,\nlower priority than CLI

== Step 3: Try credential store ==
RESOLVE -> RESOLVE : args.use_stored set?
alt --use-stored
  RESOLVE -> STORE : load(store_passphrase)
  alt keyring backend
    STORE -> KEYRING : get_password()
    KEYRING --> STORE : email + password
  else encrypted-file backend
    STORE -> ENCFILE : read credentials.enc
    ENCFILE --> STORE : encrypted payload
    STORE -> STORE : PBKDF2 + Fernet\n  decrypt
  end
  STORE --> RESOLVE : Credentials
  RESOLVE --> MAKE : email, password
end

== Step 4: Prompt user ==
alt email still missing
  USER -> RESOLVE : input("Bitwarden email: ")
end
alt password still missing
  USER -> RESOLVE : getpass("Master password: ")
end

RESOLVE --> MAKE : final Credentials\n  (email + password)

@enduml
